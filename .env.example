# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_PROJECT_ID=your-project-ref
SUPABASE_REST_URL=https://your-project-ref.supabase.co/rest/v1/
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Database
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-1-sa-east-1.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Auth (OTP)
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAILS=admin@pulsoeleitoral.ms
# Optional: Supabase access token from an allowed admin user, used only by npm run smoke:security
# Required by npm run smoke:admin
ADMIN_SMOKE_TOKEN=

# Security
ENCRYPTION_KEY=your-32-char-encryption-key
EVALUATION_SESSION_SECRET=your-session-hmac-secret
JWT_SECRET=your-jwt-secret

# Analytics (Optional)
NEXT_PUBLIC_GA_ID=

# Operations
AUDIT_LOG_RETENTION_DAYS=365
PROFILE_RETENTION_DAYS=730
IBGE_CEPS_MS_PARQUET_PATH=
NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=privacidade@pulsoeleitoral.ms
